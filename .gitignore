# ── Cloudflare / Wrangler ──
.wrangler/                 # local D1 state, dev cache — machine-specific, never shared
.dev.vars                  # local secret env vars (Razorpay keys etc) — NEVER commit this
.dev.vars.*
!.dev.vars.example          # template file is fine to commit (see below)

# ── Node ──
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json.bak

# ── Env / secrets (belt and suspenders beyond .dev.vars) ──
.env
.env.local
.env.*.local

# ── OS / editor cruft ──
.DS_Store
Thumbs.db
.vscode/
.idea/

# ── Build/output (if you ever add a bundler step) ──
dist/
build/

# ── Logs ──
*.log